GOOGLE_API_KEY=
GEMINI_API_KEY=
OAKWELL_INTERNAL_API_SECRET=
OAKWELL_FIRESTORE_PROJECT=
OAKWELL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
OAKWELL_FAST_MODEL=gemini-2.5-flash
WATCHER_INTERVAL=3600
OAKWELL_ALLOW_EPHEMERAL_MEMORY_FALLBACK=0

# Local-only escape hatch. Do not enable in shared or production environments.
OAKWELL_ALLOW_INSECURE_LOCAL_AUTH=0
OAKWELL_LOCAL_USER_ID=streamlit-local
OAKWELL_LOCAL_ORG_ID=
